# --- LLM provider -----------------------------------------------------
# One of: openai | anthropic | gemini | openrouter | ollama
LLM_PROVIDER=openai
# Model id WITHOUT the provider prefix (the provider adds its LiteLLM route).
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# Set the key for the provider you selected (others can stay empty).
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional: your model's prices per 1M tokens (USD) for run-cost estimates.
# Left empty -> cost shows as "n/a". Prices change; the operator owns them.
LLM_PRICE_INPUT_PER_1M=
LLM_PRICE_OUTPUT_PER_1M=

# --- Prompts ------------------------------------------------------------
# Which prompts/<agent>_<version>.md files agents load (see prompts/).
PROMPT_VERSION=v2

# --- Feature flags --------------------------------------------------------
USE_VALIDATOR_AGENT=true   # false = skip the agent; ValidatorEngine still runs
USE_CACHE=true             # TTL cache over the metrics repository
USE_SQLITE=false           # SQLite metrics backend (roadmap)
USE_BUSINESS_MEMORY=true   # engagement history tool + run recording
CACHE_TTL_SECONDS=300

# --- Orchestration ---------------------------------------------------------
AGENT_VERBOSE=true
AGENT_MAX_ITERATIONS=6

# --- Observability -----------------------------------------------------------
LOG_LEVEL=INFO

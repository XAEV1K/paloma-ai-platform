# ==========================================================================
# Paloma AI Platform — configuration surface
# Copy to .env and fill in the credential for your LLM_PROVIDER.
# NEVER commit .env. Rotate any key that has ever left your machine.
# ==========================================================================

# --- Application -----------------------------------------------------------
APP_NAME="Paloma AI Decision Platform"
ENVIRONMENT=development        # development | staging | production
DEBUG=false                    # true forces DEBUG logging

# --- LLM routing -------------------------------------------------------------
# Default vendor for model ids without a known prefix
# (openai | anthropic | gemini | openrouter | ollama).
LLM_PROVIDER=openrouter

# Fallback model for any role without an explicit MODEL_<ROLE>.
# With openrouter, ALWAYS write the full catalog path (vendor included).
LLM_MODEL=openrouter/openai/gpt-4o-mini

# Per-role assignments — different jobs, different models:
#   Architect  = strongest reasoner (the diagnosis is the product)
#   Developer  = fast, reliable tool-caller (structured work, many calls)
#   Validator  = cheapest relay (it repeats a machine verdict, T=0)
# Verify exact slugs in the OpenRouter catalog (openrouter.ai/models).
MODEL_ARCHITECT=openrouter/anthropic/claude-sonnet-5
MODEL_DEVELOPER=openrouter/openai/gpt-4o-mini
MODEL_VALIDATOR=openrouter/google/gemini-2.5-flash

# Global temperature override. Leave unset for per-role defaults
# (architect 0.2 / developer 0.1 / validator 0.0).
#LLM_TEMPERATURE=

# Credential for the provider(s) you actually use; others stay empty.
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional: blended prices per 1M tokens (USD) for run-cost estimates.
# Left empty -> cost shows as "n/a". Prices change; the operator owns them.
LLM_PRICE_INPUT_PER_1M=
LLM_PRICE_OUTPUT_PER_1M=

# --- Prompts -------------------------------------------------------------------
# Which prompts/<agent>_<version>.md files agents load (see prompts/).
PROMPT_VERSION=v3

# --- Feature flags ----------------------------------------------------------------
USE_VALIDATOR_AGENT=true   # false = skip the agent; ValidatorEngine still runs
USE_CACHE=true             # TTL cache over the metrics repository
USE_SQLITE=false           # SQLite metrics backend (roadmap)
USE_BUSINESS_MEMORY=true   # engagement history tool + run recording
CACHE_TTL_SECONDS=300

# --- Orchestration -------------------------------------------------------------------
AGENT_VERBOSE=true
AGENT_MAX_ITERATIONS=6

# --- Observability ---------------------------------------------------------------------
LOG_LEVEL=INFO
